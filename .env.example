# Vercel → Project → Settings → Environment Variables
# Required for `studio` build on Vercel (and local studio dev in /studio).

SANITY_STUDIO_PROJECT_ID=yourProjectId
SANITY_STUDIO_DATASET=production

# Optional aliases (if you already created these on Vercel):
# SANITY_PROJECT_ID=
# SANITY_DATASET=
# NEXT_PUBLIC_SANITY_PROJECT_ID=

# For fetching content from the marketing site later (server/build only):
# SANITY_API_READ_TOKEN=

# One-time photo migration into Sanity (Editor token, never commit):
# SANITY_API_TOKEN=
# Then: npm install && npm run migrate:photos
# In sanity.io/manage → API → enable public read on your dataset so the browser can GROQ without a token.

# ─── Lead capture (Notion + Resend) ───
NOTION_API_KEY=
NOTION_LEADS_DB_ID=899cfc17c95c80929e26c20ee3ff2d1b
RESEND_API_KEY=
RESEND_FROM_EMAIL=Stone House <admin@stonehouse.io>

# ─── Analytics ───
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
