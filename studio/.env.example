# Copy to .env for local `npm run dev` in this folder.
# Match the variable names you use on Vercel (any one project id key is enough).

SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Alternatives also supported in sanity.config.ts / sanity.cli.ts:
# SANITY_PROJECT_ID=
# SANITY_DATASET=
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=
